{
  "name": "gitick---task-manager",
  "private": true,
  "version": "0.2.115",
  "description": "Gitick desktop task manager",
  "author": "Myrick Wang",
  "repository": {
    "type": "git",
    "url": "https://github.com/rickkwang/Gitick.git"
  },
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite --configLoader runner",
    "build": "vite build",
    "build:stable": "node scripts/run-command-stable.mjs --label build --timeout 180000 --retries 1 --cleanup \"rm -rf node_modules/.vite\" -- \"vite build\"",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck",
    "ci:local": "npm run typecheck && npm run build:stable",
    "preview": "vite preview --configLoader runner",
    "desktop:dev": "concurrently -k \"vite --host 127.0.0.1 --port 3000\" \"wait-on tcp:3000 && VITE_DEV_SERVER_URL=http://127.0.0.1:3000 electron .\"",
    "desktop:pack": "npm run build:stable && electron-builder --dir",
    "desktop:dmg": "npm run build:stable && electron-builder --mac",
    "desktop:release": "npm run clean:release && npm run desktop:dmg && node scripts/verify-mac-signatures.mjs && node scripts/publish-desktop-release.mjs",
    "clean:release": "node scripts/clean-release.mjs",
    "desktop:release:signed": "node scripts/check-notarization-env.mjs && npm run desktop:release",
    "test": "vitest",
    "test:run": "vitest run",
    "test:run:stable": "node scripts/run-command-stable.mjs --label test --timeout 180000 --retries 1 -- \"vitest run\"",
    "desktop:ci:smoke": "npm run build:stable && electron-builder --mac zip --publish never",
    "desktop:ci:verify-artifacts": "node scripts/verify-mac-updater-artifacts.mjs"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "electron-updater": "^6.6.2",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "electron": "^37.2.1",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.27.4",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.1"
  },
  "build": {
    "appId": "com.rickkwang.gitick.desktop",
    "productName": "Gitick",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "afterSign": "scripts/notarize.cjs",
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "icon": "build/icon.png"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "title": "${productName} ${version}"
    },
    "publish": {
      "provider": "github",
      "owner": "rickkwang",
      "repo": "Gitick"
    }
  },
  "overrides": {
    "yauzl": "^3.2.1"
  }
}
