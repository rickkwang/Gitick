<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Required for Electron's JIT behavior in renderer -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- Required for loading unsigned modules (used by some bundlers) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- REMOVED: allow-unsigned-executable-memory is a security risk and blocks Mac App Store -->
  </dict>
</plist>

